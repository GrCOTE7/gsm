#!/usr/bin/env bash

set -euo pipefail

# Git User Switcher (Linux/Codespaces)
# Usage:
#   ./gu        -> show current git identity
#   ./gu mp     -> set MP identity
#   ./gu gc7    -> set GrCOTE7 identity

set_name="${1:-}"

# Allowed values
if [[ -n "$set_name" && "$set_name" != "mp" && "$set_name" != "gc7" ]]; then
    echo "Usage: ./gu [mp|gc7]"
    exit 1
fi

# Read secrets (Codespaces)
email_mp="${EMAIL_MP:-}"
email_gc7="${EMAIL_GC7:-}"

# Function to get identity from any level
get_git_value() {
    git config --local "$1" 2>/dev/null && return
    git config --global "$1" 2>/dev/null && return
    git config --system "$1" 2>/dev/null && return
    echo ""
}

# Show identity
if [[ -z "$set_name" ]]; then
    name="$(get_git_value user.name)"
    email="$(get_git_value user.email)"

    echo "Current Git identity (local > global > system):"
    echo "  user.name  = ${name}"
    echo "  user.email = ${email}"
    exit 0
fi

# Apply identity (always global)
case "$set_name" in
    mp)
        git config --global user.name "MP21170"
        git config --global user.email "${email_mp:-undefined}"
        echo "Git identity set to MP"
    ;;
    gc7)
        git config --global user.name "GrCOTE7"
        git config --global user.email "${email_gc7:-undefined}"
        echo "Git identity set to GrCOTE7"
    ;;
esac
