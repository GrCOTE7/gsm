{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: main.py (Up U)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/main.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": true
    },
    {
      "name": "Python: Flet run main.py",
      "type": "debugpy",
      "request": "launch",
      "module": "flet.cli",
      "args": [
        "run",
        "-r",
        "src/main.py"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": true
    }
  ]
}
