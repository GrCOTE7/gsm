{
"window.title": "${dirty}${activeEditorShort}${separator}${activeRepositoryBranchName}${separator}${rootName}${separator}${activeEditorMedium}",
//
"editor.lineHeight": 20,
//
"files.autoSave": "afterDelay",
"files.autoSaveDelay": 2100,
//
"todo-tree.general.tags": [
  "2fix",
  "☢️",
  "2dbug",
  "2ar",
  "* [-]",
  "* [ ]",
  "2do",
  "🎯",
  "❌",
  "2let",
  "🦄",
  "XXX",
  "2see",
  "1fo"
  ],
  "todo-tree.highlights.enabled": true,
  "todo-tree.highlights.highlightDelay": 1500,
  "todo-tree.highlights.defaultHighlight": {
    "foreground": "#0F0",
    "type": "none"
  },
  "todo-tree.highlights.customHighlight": {
    "2fix": {
      "icon": "check",
      "type": "line",
      "foreground": "#FFFF00",
    },
    "☢️": {
      "icon": "check",
      "type": "line",
      "foreground": "#e785ff",
      "iconColour": "#f00"
    },
    "2dbug": {
      "icon": "check",
      "type": "line",
      "foreground": "#c07700",
      "iconColour": "#f00"
    },
    "2ar": {
      "icon": "check",
      "type": "line",
      "foreground": "#f0f",
    },
    "* [-]": {
      "icon": "check",
      "type": "line",
      "foreground": "#fff0a5",
    },
    "* [ ]": {
      "icon": "check",
      "type": "line",
      "foreground": "#FAB31A",
    },
    "2do": {
      "icon": "check",
      "type": "line",
      "foreground": "#FAB31A",
    },
    "🎯": {
      "icon": "check",
      "type": "line",
      "foreground": "#a1c2ff",
      "iconColour": "#a1c2ff"
    },
    "❌": {
      "icon": "check",
      "type": "line",
      "foreground": "#ff6060",
      "iconColour": "#ff6060"
    },
    "2see": {
      "icon": "check",
      "type": "line",
      "foreground": "#0FF",
    },
    "2let": {
      "icon": "check",
      "type": "line",
      "foreground": "#0F0",
    },
    "1fo": {
      "icon": "check",
      "type": "line",
      "foreground": "#0F0",
    },
    "🦄": {
      "icon": "check",
      "type": "line",
      "foreground": "#f0f"
    },
    "XXX": {
      "icon": "check",
      "type": "line",
      "foreground": "#a0a0a0",
      "iconColour": "#F00"
    }
  },
  "todo-tree.general.statusBar": "tags",
  "todo-tree.tree.showCountsInTree": true,
  "todo-tree.general.statusBarClickBehaviour": "cycle",
  "todo-tree.general.debug": true,
  "todo-tree.general.rootFolder": "${workspaceFolder}",
  "todo-tree.tree.scanMode": "workspace",
  "todo-tree.tree.scanAtStartup": true,
  "todo-tree.tree.expanded": true,
  "todo-tree.tree.flat": false,
  "todo-tree.tree.grouped": false,
  "todo-tree.tree.tagsOnly": false,
  "editor.tabCompletion": "on",
  // "todo-tree.regex.regex": "(@n|@v|@!|@\\?)",
  // "todo-tree.regex.regex": "((//|#|<!--|;|/\\*|^[ \\t]*(-|\\d+\\.))\\s*)?($TAGS)",
  // "todo-tree.tree.labelFormat": "${after}",
  // "todo-tree.regex.regex": "(2fix|2do|2dbug|2ar|2see|XXX|🎯|❌|🦄|\\* \ \[ \\] |\\* \ \[-\\] |@n|@v|@!|@\\?)",
  // "todo-tree.regex.regex": "(1fo)",
  "todo-tree.filtering.excludeGlobs": [
    "**/scan_todos/**",
    "**/.env/**",
    "**/.vscode/**",
    "**/site/**", 
    "**/node_modules/**",
    "**/__pycache__/**",
    "**/.git/**",
    "**/scripts/todo_tags.md"
  ],
  // CodeSpaces
  "task.allowAutomaticTasks": "on",
  //
  "editor.snippetSuggestions": "top",
  "python-envs.defaultEnvManager": "ms-python.python:venv",
  "git.ignoreLimitWarning": true,
  "python.analysis.useLibraryCodeForTypes": true,
  "python.analysis.typeCheckingMode": "basic",
  "auto-close-tag.disableOnLanguage": [],
