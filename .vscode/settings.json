{
"window.title": "${dirty}${activeEditorShort}${separator}${activeRepositoryBranchName}${separator}${rootName}${separator}${activeEditorMedium}",

  "windows": {
    "todo-tree.ripgrep.ripgrep": "C:\\Tools\\ripgrep\\rg.exe"
  },

  "linux": {
    "todo-tree.ripgrep.ripgrep": "/usr/bin/rg"
  },

  "todo-tree.general.tags": [
    "2fix",
    "☢️",
    "2dbug",
    "2ar",
    "* [-]",
    "* [ ]",
    "2do",
    "🎯",
    "❌",
    "2let",
    "🦄",
    "XXX",
    "2see"
  ],
  "todo-tree.highlights.enabled": true,
  "todo-tree.highlights.highlightDelay": 1500,
  "todo-tree.highlights.defaultHighlight": {
    "foreground": "#0F0",
    "type": "none"
  },
  "todo-tree.highlights.customHighlight": {
    "2fix": {
      "icon": "check",
      "type": "line",
      "foreground": "#FF0",
      "iconColour": "#FF0"
    },
    "☢️": {
      "icon": "check",
      "type": "line",
      "foreground": "#8a7c00",
      "iconColour": "#8a7c00"
    },
    "2dbug": {
      "icon": "check",
      "type": "line",
      "foreground": "#c07700",
      "iconColour": "#c07700"
    },
    "2ar": {
      "icon": "check",
      "type": "line",
      "foreground": "#f0f",
      "iconColour": "#f0f"
    },
    "* [-]": {
      "icon": "check",
      "type": "line",
      "foreground": "#fff0a5",
      "iconColour": "#fff0a5"
    },
    "* [ ]": {
      "icon": "check",
      "type": "line",
      "foreground": "#ff0",
      "iconColour": "#ff0"
    },
    "2do": {
      "icon": "check",
      "type": "line",
      "foreground": "#f00",
      "iconColour": "#f00"
    },
    "🎯": {
      "icon": "check",
      "type": "line",
      "foreground": "#f00",
      "iconColour": "#f00"
    },
    "❌": {
      "icon": "check",
      "type": "line",
      "foreground": "#f00",
      "iconColour": "#f00"
    },
    "2see": {
      "icon": "check",
      "type": "line",
      "foreground": "#0FF",
      "iconColour": "#0FF"
    },
    "2let": {
      "icon": "check",
      "type": "line",
      "foreground": "#0F0",
      "iconColour": "#0F0"
    },
    "🦄": {
      "icon": "check",
      "type": "line",
      "foreground": "#f0f",
      "iconColour": "#f0f"
    },
    "XXX": {
      "icon": "check",
      "type": "line",
      "foreground": "#f0f",
      "iconColour": "#f0f"
    }
  },
  "todo-tree.general.statusBar": "tags",
  "todo-tree.tree.showCountsInTree": true,
  "todo-tree.general.statusBarClickBehaviour": "cycle",
  "todo-tree.general.debug": true,
  "todo-tree.general.rootFolder": "${workspaceFolder}",
  "todo-tree.filtering.excludeGlobs": [
    "**/scan_todos/**",
    "**/.env/**",
    "**/site/**",
    "**/node_modules/**",
    "**/__pycache__/**",
    "**/.git/**"
  ],
  "todo-tree.tree.scanMode": "workspace",
  "todo-tree.tree.scanAtStartup": true,
  "todo-tree.tree.expanded": true,
  "todo-tree.tree.flat": false,
  "todo-tree.tree.grouped": false,
  "todo-tree.tree.tagsOnly": false,
  "editor.tabCompletion": "on",
  "editor.snippetSuggestions": "top",
  // "todo-tree.regex.regex": "((//|#|<!--|;|/\\*|^[ \\t]*(-|\\d+\\.))\\s*)?($TAGS)",
  "todo-tree.tree.labelFormat": "${after}",
  "python-envs.defaultEnvManager": "ms-python.python:venv",
  // "python.defaultInterpreterPath": "d:/Py/.venv313/Scripts/python.exe",
  "git.ignoreLimitWarning": true,
  "python.analysis.useLibraryCodeForTypes": true,
  "python.analysis.typeCheckingMode": "basic",
  "cSpell.words": [
    "ajoute",
    "ajouté",
    "ajouter",
    "chrono",
    "contient",
    "début",
    "fichiers",
    "flet",
    "insère",
    "ipynb",
    "kevindegila",
    "machinelearnia",
    "mais",
    "Modifié",
    "Parcours",
    "première",
    "préparées",
    "présent",
    "récursif",
    "sauvegarde",
    "SAUVEGARDE",
    "sauvegardées",
    "selon",
    "tous",
    "tutos"
  ],
  "advancedNewFile.convenienceOptions": [
    
    "last",
    "current",
    "root"
  ],
  //
  "better-comments.highlightPlainText": true,
  "better-comments.tags": [
    {
      "tag": "@!",
      "color": "#ffffff",
      "strikethrough": false,
      "backgroundColor": "transparent",
    },
    {
      "tag": "@bug",
      "color": "#FF4901",
      "strikethrough": false,
      "backgroundColor": "transparent",
    },
    {
      "tag": "@n",
      "color": "#ffcf39",
      "strikethrough": false,
      "backgroundColor": "transparent",
    },
    {
      "tag": "@i",
      "color": "#0ff",
      "strikethrough": false,
      "backgroundColor": "transparent",
    },
    {
      "tag": "***",
      "color": "#5eff00",
      "strikethrough": false,
      "backgroundColor": "transparent",
    },
    {
      "tag": "@?",
      "color": "#0000FF",
      "strikethrough": false,
      "backgroundColor": "transparent",
    },
    {
      "tag": "2ar",
      "color": "#f0f",
      "strikethrough": false,
      "backgroundColor": "transparent",
    },
    {
      "tag": "@2q",
      "color": "#ff0",
      "strikethrough": false,
      "backgroundColor": "transparent",
    },
    {
      "tag": "@s",
      "color": "#fff",
      "strikethrough": false,
      "backgroundColor": "transparent",
    },
    {
      "tag": "@dl",
      "color": "#7ff",
      "strikethrough": false,
      "backgroundColor": "transparent",
    },
    {
      "tag": "2see",
      "color": "#FF8C00",
      "strikethrough": false,
      "backgroundColor": "transparent",
    },
  ],
}
