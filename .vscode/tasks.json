{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run quick_test.py with hotreload",
      "type": "shell",
      "command": "uvx watchfiles \"uv run python quick_test.py\" .",
      "isBackground": true,
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false
      },
      "problemMatcher": [],
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
