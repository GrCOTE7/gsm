{
  "name": "Mon Codespace GSM",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "mhutchie.git-graph",
        "hnw.vscode-auto-open-markdown-preview",
        "gruntfuggly.todo-tree",
        "ms-toolsai.jupyter",
        "aaron-bond.better-comments",
        "natqe.reload",
        "eprincev-egor.toggle-upper-case"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python3.13",
        "todo-tree.ripgrep.ripgrep": "/usr/bin/vscode-ripgrep",
        "workbench.editorRestoreMode": "all",
        "workbench.startupEditor": "readme",
        "explorer.openEditors.visible": 7
      },
      "keybindings": [
        {
          "key": "F8",
          "command": "workbench.action.terminal.sendSequence",
          "args": {
            // "text": "uvx watchfiles quick_test.py . 2>/dev/null\u000D"
            "text": "uvx watchfiles \"uv run python quick_test.py\" ."
          }
        },
        {
          "key": "F9",
          "command": "python.execInTerminal"
        }
      ]
    }
  },
  "postCreateCommand": "chmod +x .devcontainer/postCreateCommand.sh && ./.devcontainer/postCreateCommand.sh",

  // "postAttachCommand": "code quick_test.py && code scripts/essays/salutation.py && uvx watchfiles \"uv run python quick_test.py\" ."
  // XXX Reprendre mise au point codespace start automatically watchfiles
  "postAttachCommand": "code quick_test.py && code scripts/essays/salutation.py"

  // Le watcher doit être lancé depuis la tâche VS Code, pas via postAttachCommand.
  // "postAttachCommand": "nohup sh -c 'uvx watchfiles \"uv run python quick_test.py\" .' >/tmp/uvx_quick_test.log 2>&1 &"

  // * [ ] 2test postStartCommand": "nohup uvx watchfiles --command 'uv run python quick_test.py' . >/tmp/quick_test.log 2>&1 &"
  // * [ ] 2test postStartCommand": "nohup uvx watchfiles uv run python quick_test.py' . >/tmp/quick_test.log 2>&1 &"
  
  // "postStartCommand": "uvx watchfiles 'uv run python quick_test.py' ."

// L'ordre est :
// postCreateCommand → exécuté une seule fois lors de la création initiale du conteneur/Codespace.
// postStartCommand → exécuté à chaque démarrage du conteneur.
// postAttachCommand → exécuté à chaque fois qu'un client VS Code s'attache au conteneur.

}